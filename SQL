	CREATE FUNCTION GetCategorySalesByYear (@Year INT)
RETURNS TABLE
AS
RETURN
(
    SELECT *
    FROM (
        SELECT 
            DATENAME(MONTH, T.TransactionDate) AS MonthName,
            I.Category AS ProductCategory,
            COUNT(*) AS TotalSales
        FROM TRANSACTIONS AS T
        JOIN ITEMS AS I ON T.TransNumber = I.TransNumber
        WHERE YEAR(T.TransactionDate) = @Year  
        GROUP BY DATENAME(MONTH, T.TransactionDate), I.Category
    ) AS SourceTable
    PIVOT (                
        SUM(TotalSales)
        FOR MonthName IN ([January], [February], [March], [April], [May], [June], 
                          [July], [August], [September], [October], [November], [December])
    ) AS PivotTable
);

