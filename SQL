CREATE TRIGGER trg_BeforeDeleteTransaction
ON TRANSACTIONS
INSTEAD OF DELETE
AS
BEGIN
    -- 1. Storing data from DELETED into a temporary table.
    SELECT D.TRANSNUMBER, I.CATEGORY
    INTO #TempDeleted
    FROM DELETED D
    INNER JOIN ITEMS I ON D.TRANSNUMBER = I.TRANSNUMBER;

-- 2. Update the ITEMS table so that the TRANSNUMBER of the product is set to NULL.
    UPDATE ITEMS
    SET TRANSNUMBER = NULL
    WHERE TRANSNUMBER IN (SELECT TRANSNUMBER FROM DELETED);

  -- 3. Update the CANCELEDTRANSACTIONS table with data from the temporary table.
    MERGE INTO CANCELEDTRANSACTIONS AS target
    USING (
        SELECT CATEGORY, COUNT(*) AS CancellationsCount
        FROM #TempDeleted
        GROUP BY CATEGORY
    ) AS source
    ON target.CATEGORY = source.CATEGORY
    WHEN MATCHED THEN
        UPDATE SET NumberCancellations = NumberCancellations + source.CancellationsCount
    WHEN NOT MATCHED BY TARGET THEN
        INSERT (CATEGORY, NumberCancellations)
        VALUES (source.CATEGORY, source.CancellationsCount);

    -- 4. Deleting records from the TRANSACTIONS table.
    DELETE FROM TRANSACTIONS
    WHERE TRANSNUMBER IN (SELECT TRANSNUMBER FROM #TempDeleted);

-- Cleaning up the temporary table.
    DROP TABLE #TempDeleted;
END;




