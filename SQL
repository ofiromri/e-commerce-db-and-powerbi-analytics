CREATE PROCEDURE Process_Transaction
    @TransNumber NVARCHAR(15),
    @CreditCardNumber NVARCHAR(20),
    @CVV INT,
    @FinalPrice MONEY,
    @TransactionDate DATE,
    @Buyer NVARCHAR(20),
    @Seller NVARCHAR(20)
AS
BEGIN
    BEGIN TRY
        -- Step 1: Validate the credit card details (existence, CVV match, and expiration date)
        IF NOT EXISTS (
            SELECT 1
            FROM CREDITCARDS
            WHERE CreditCard = @CreditCardNumber
              AND CVV = @CVV
              AND ExpireDT >= GETDATE()
        )
        BEGIN
            -- Throw a custom error if the credit card validation fails
            THROW 50001, 'Invalid Credit Card: Details do not match or the card is expired.', 1;
        END

        -- Step 2: Insert the transaction into the TRANSACTIONS table
        INSERT INTO TRANSACTIONS (TransNumber, CreditCardNumber, FinalPrice, TransactionDate, Buyer, Seller)
        VALUES (@TransNumber, @CreditCardNumber, @FinalPrice, @TransactionDate, @Buyer, @Seller);

        PRINT 'Transaction processed successfully.';
    END TRY
    BEGIN CATCH
        -- Step 3: Handle the error and rollback the transaction if necessary
        IF EXISTS (
            SELECT 1
            FROM TRANSACTIONS
            WHERE TransNumber = @TransNumber
        )
        BEGIN
            DELETE FROM TRANSACTIONS
            WHERE TransNumber = @TransNumber;
        END

        PRINT 'Transaction failed and was rolled back.';
    END CATCH
	END;

