CREATE VIEW CategoryReport AS

WITH 
   -- Subquery 1: Identifying products that were not purchased but were searched frequently. 
    ProductSearches AS (
        SELECT 
        s.ItemID,
        i.Category,
        COUNT(s.ItemID) AS SearchCount,
        i.Condition,
        i.Price,
        i.UserName
    FROM SEARCHES s
    JOIN ITEMS i ON s.ItemID = i.ItemID
    GROUP BY s.ItemID, i.Category, i.Condition, i.Price, i.TransNumber, i.UserName
    HAVING COUNT(s.ItemID) > 15 AND i.TransNumber IS NULL
    ),

   -- Subquery 2: Sellers with fewer than 3 transactions.
    SellerTransactions AS (
        SELECT 
            t.Seller,
            COUNT(*) AS SellerTransactions
        FROM TRANSACTIONS t
        GROUP BY t.Seller
        HAVING COUNT(*) < 10 -- Sellers with fewer than 3 transactions.
    ),

   -- Subquery 3: Calculating the average price by categories.
    AvgCategoryPrices AS (
        SELECT 
            i.Category,
            AVG(i.Price) AS AvgPrice
        FROM ITEMS i
        GROUP BY i.Category
    ),

  -- Subquery 4: Joining all data related to the product (searches, sellers, average prices).
    ProductDetails AS (
        SELECT 
            i.ItemID,
            i.Category,
            i.UserName,
            i.Price,
            i.Condition,
            ps.SearchCount,
            st.Seller,
            ac.AvgPrice
        FROM 
            ITEMS i
        JOIN 
            ProductSearches ps ON i.ItemID = ps.ItemID  
        LEFT JOIN 
            SellerTransactions st ON i.UserName = st.Seller  
        JOIN 
            AvgCategoryPrices ac ON i.Category = ac.Category 
    )

SELECT 
    pd.Category,
    COUNT(DISTINCT pd.ItemID) AS ProductCount,
    SUM(CASE WHEN pd.Condition = 'Used' THEN 1 ELSE 0 END) AS UsedProducts,
    SUM(CASE WHEN pd.Seller IS NOT NULL THEN 1 ELSE 0 END) AS UnreliableSellers,
    SUM(CASE WHEN pd.Price > pd.AvgPrice THEN 1 ELSE 0 END) AS HighPriceProducts
FROM 
    ProductDetails pd
GROUP BY 
    pd.Category
ORDER BY 
    pd.Category;






