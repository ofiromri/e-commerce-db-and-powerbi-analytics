CREATE VIEW Month_Sales AS
SELECT 
    YEAR(T.TransactionDate) AS SaleYear, 
    MONTH(T.TransactionDate) AS SaleMonth, 
    COUNT(*) AS TotalItemsSold, 
    SUM(T.FinalPrice) AS TotalSalesPrice,
    (SELECT TOP 1 I.Category
     FROM ITEMS AS I
     JOIN TRANSACTIONS AS T2 ON I.TransNumber = T2.TransNumber
     WHERE YEAR(T2.TransactionDate) = YEAR(T.TransactionDate) 
       AND MONTH(T2.TransactionDate) = MONTH(T.TransactionDate)
       AND I.TransNumber IS NOT NULL  -- Ensure that a transaction has been made.
     GROUP BY I.Category
     ORDER BY SUM(T2.FinalPrice) DESC) AS BestSellingCategory
FROM TRANSACTIONS AS T
GROUP BY 
    YEAR(T.TransactionDate), 
    MONTH(T.TransactionDate);

	SELECT 
    SaleMonth,
    TotalItemsSold,
    TotalSalesPrice,
    BestSellingCategory,
    TotalSalesPrice / TotalItemsSold AS AveragePricePerItem
FROM Month_Sales
WHERE SaleYear = 2024;




