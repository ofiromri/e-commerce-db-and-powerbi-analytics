CREATE PROCEDURE SmartItemPromotions
    @MinSearches INT,     -- The minimum number of searches for a product to avoid being considered "not popular".
    @Months INT,             -- The number of recent months to be used in the active customers function.
    @TopN INT             -- The maximum number of ratings to be displayed for each customer.

AS
BEGIN
  -- Step 1: Create a list of products with few searches.
    SELECT I.ItemID, 
           ISNULL(I.Category, 'Unknown') AS Category, -- Handling NULL in the category.
           ISNULL(I.UserName, 'Unknown') AS SellerID  -- Handling NULL in the seller.
    INTO #LowSearchItems
    FROM ITEMS I
    LEFT JOIN SEARCHES S ON I.ItemID = S.ItemID
    WHERE (S.SearchDT >= DATEADD(MONTH, -@Months, GETDATE()) OR S.SearchDT IS NULL) 
          AND I.TransNumber IS NULL
    GROUP BY I.ItemID, I.Category, I.UserName
    HAVING COUNT(S.SearchDT) < @MinSearches;

-- Step 2: Retrieve a list of active customers using the function.
    SELECT ISNULL(GBB.Buyer, 'Unknown') AS Buyer  
    INTO #ActiveCustomers
    FROM dbo.Get_Active_Buyers_By_Date(@Months) AS GBB;


-- Step 3: Create a match between active customers and products with few searches.
    SELECT DISTINCT 
        AC.Buyer,  
        LSI.ItemID,
        LSI.Category,
        LSI.SellerID,
        ROW_NUMBER() OVER (
            PARTITION BY AC.Buyer, LSI.ItemID  -- Add LSI.ItemID to ensure uniqueness.
            ORDER BY 
                CASE 
                  -- Higher rating if both the category and the seller were found in previous searches.
                    WHEN ISNULL(LSI.Category, 'Unknown') IN (
                        SELECT DISTINCT ISNULL(I.Category, 'Unknown')  
                        FROM SEARCHES S  
                        JOIN ITEMS I ON S.ItemID = I.ItemID
                        WHERE S.UserName = AC.Buyer  
                    ) AND ISNULL(LSI.SellerID, 'Unknown') IN (
                        SELECT DISTINCT ISNULL(S.UserName, 'Unknown')  
                        FROM SEARCHES S  
                        WHERE S.UserName = AC.Buyer  
                    ) THEN 1
                -- Medium rating if only the category matches.
                    WHEN ISNULL(LSI.Category, 'Unknown') IN (
                        SELECT DISTINCT ISNULL(I.Category, 'Unknown')  
                        FROM SEARCHES S  
                        JOIN ITEMS I ON S.ItemID = I.ItemID
                        WHERE S.UserName = AC.Buyer  
                    ) THEN 2
                    -- Low rating if only the seller matches.
                    WHEN ISNULL(LSI.SellerID, 'Unknown') IN (
                        SELECT DISTINCT ISNULL(S.UserName, 'Unknown')  
                        FROM SEARCHES S  
                        WHERE S.UserName = AC.Buyer  
                    ) THEN 3
					-- Very low rating if there is no match.
                    ELSE 4
                END, 
                LSI.ItemID
        ) AS Rank
    INTO #RankedPromotions
    FROM #ActiveCustomers AC
    JOIN SEARCHES S ON AC.Buyer = S.UserName
    JOIN #LowSearchItems LSI ON S.ItemID = LSI.ItemID;

	-- Step 4: Select ratings for each customer based on input (TopN) and remove duplicates.
    WITH DistinctPromotions AS (
        SELECT DISTINCT RP.Buyer, 
                        LSI.ItemID, 
                        LSI.Category, 
                        LSI.SellerID
        FROM #RankedPromotions RP
        JOIN #LowSearchItems LSI ON RP.ItemID = LSI.ItemID
        WHERE RP.Rank <= @TopN
    )
    SELECT Buyer, 
           STRING_AGG(CONCAT(ItemID, ':', Category, ':', SellerID), ', ') AS Recommendations
    INTO #TopNPromotions
    FROM DistinctPromotions
    GROUP BY Buyer;

    -- Display the results.
    SELECT Buyer, Recommendations
    FROM #TopNPromotions;

-- Clean up the temporary tables.
    DROP TABLE #LowSearchItems;
    DROP TABLE #ActiveCustomers;
    DROP TABLE #RankedPromotions;
    DROP TABLE #TopNPromotions;
	END;

EXECUTE SmartItemPromotions @MinSearches = 2, @Months = 6, @TopN = 3;

