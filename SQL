	CREATE FUNCTION dbo.GetMonthContribution
(
    @Year INT,
    @Month INT
)
RETURNS FLOAT
AS
BEGIN
    DECLARE @MonthSales FLOAT;
    DECLARE @YearSales FLOAT;
    DECLARE @Contribution FLOAT;

   -- Total sales for the requested month.
    SELECT @MonthSales = SUM(TotalSalesPrice)
    FROM Month_Sales
    WHERE SaleYear = @Year AND SaleMonth = @Month;

   -- Total sales for the requested year.
    SELECT @YearSales = SUM(TotalSalesPrice)
    FROM Month_Sales
    WHERE SaleYear = @Year;

	-- Calculating the relative contribution.
    SET @Contribution = ISNULL(@MonthSales / NULLIF(@YearSales, 0), 0);

    RETURN @Contribution;
END;



